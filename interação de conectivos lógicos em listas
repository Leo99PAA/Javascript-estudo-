const A = [1, 2, 3, 4];
const B = [3, 4, 5, 6];

const uniao = [...new Set([...A, ...B])];
const intersecao = A.filter(x => B.includes(x));
const diferenca = A.filter(x => !B.includes(x));

console.log("União:", uniao);
console.log("Interseção:", intersecao);
console.log("Diferença (A - B):", diferenca);
